{
  "name": "eslint-plugin",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/eslint-plugin/src",
  "projectType": "library",
  "tags": ["scope:tooling"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/eslint-plugin",
        "command": "node tools/scripts/build-eslint-plugin.js"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/vite:test",
      "outputs": ["{workspaceRoot}/coverage/libs/eslint-plugin"],
      "options": {
        "reportsDirectory": "../../coverage/libs/eslint-plugin"
      }
    }
  }
}
